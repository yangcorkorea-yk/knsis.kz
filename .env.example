# knsis.kz — environment variables. Copy to .env.local for dev.
# MVP scope only. M-POST entries (WA/TG/SMS/OTP/Inngest) are commented out.

# ── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database / Supabase (EU, Stockholm) ───────────────────────────
# Filled in M0-03.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knsis
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/knsis
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth (Better-Auth, staff only) ────────────────────────────────
# Filled in M1-02.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GUEST_COOKIE_SECRET=

# ── Staff seed (M5-01) ────────────────────────────────────────────
# PM-only path: hash a chosen password locally with bcryptjs, then
# paste the $2b$... string here. The hash is what gets inserted —
# plaintext never crosses the Vercel boundary.
#
# To generate the hash:
#   node -e "console.log(require('bcryptjs').hashSync('<password>', 12))"
#
# Then `pnpm db:seed:staff` creates / updates the staff User row.
STAFF_SEED_EMAIL=
STAFF_SEED_PASSWORD_HASH=

# ── Email (Resend, transactional only) ────────────────────────────
# RESEND_API_KEY + RESEND_FROM filled in M4-04 for customer-facing email.
# RESEND_NOTIFY_TO filled in M3-03 for the PM "new lead" internal alert.
RESEND_API_KEY=
RESEND_FROM="knsis.kz <noreply@knsis.kz>"
RESEND_NOTIFY_TO=

# ── Photo upload (M3-02) ──────────────────────────────────────────
# Private bucket on Supabase Storage; signed URLs minted at read time.
LEAD_PHOTOS_BUCKET=lead-photos

# ── Observability ─────────────────────────────────────────────────
# Filled by ops post M0-02.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Anti-abuse ────────────────────────────────────────────────────
# Filled in M3-05. Site key is rendered in client HTML (NEXT_PUBLIC_).
# When NEXT_PUBLIC_TURNSTILE_SITE_KEY is blank the form skips the
# Turnstile widget (dev mode) and the server skips siteverify.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── RESERVED — M-POST only. Do not set in MVP. ────────────────────
# WHATSAPP_PHONE_ID=
# WHATSAPP_TOKEN=
# TELEGRAM_BOT_TOKEN=
# MOBIZON_API_KEY=
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
