// knsis.kz — starter Prisma schema. Source of truth for the data model.
// Iterate with migrations; never edit a shipped migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────

enum Locale {
  kz
  ru
  kr
}

enum Role {
  customer
  support
  manager
  head
  admin
}

enum LeadStatus {
  new
  contacted
  in_progress
  scheduled
  done
  on_hold
}

enum LeadKind {
  korea
  local
}

enum Channel {
  inapp
  wa
  tg
  sms
  email
}

enum ClinicKind {
  korea
  local
}

enum ClinicVerifyState {
  verified
  pending
  suspended
}

enum TreatmentCategory {
  skin
  botox
  filler
  lift
  acne
  pigment
  hair
  cosmetic
  scalp
}

enum ReviewState {
  pending
  flagged
  published
  rejected
}

enum MessageDirection {
  in
  out
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum AutomationTrigger {
  lead_created
  status_changed
  visit_confirmed
  review_due
}

// ─── Core entities ──────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  phone         String   @unique
  name          String?
  email         String?
  locale        Locale   @default(kz)
  role          Role     @default(customer)
  consentTos    Boolean  @default(false)
  consentMkt    Boolean  @default(false)
  consentedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  leads         Lead[]   @relation("LeadOwner")
  ownedLeads    Lead[]   @relation("LeadManager")
  reviews       Review[]
  favorites     Favorite[]
  notifications Notification[]
  sessions      Session[]
  auditLogs     AuditLog[] @relation("AuditActor")
}

model Lead {
  id            String     @id @default(uuid()) @db.Uuid
  code          String     @unique
  userId        String     @db.Uuid
  user          User       @relation("LeadOwner", fields: [userId], references: [id])
  ownerId       String?    @db.Uuid
  owner         User?      @relation("LeadManager", fields: [ownerId], references: [id])
  clinicId      String?    @db.Uuid
  clinic        Clinic?    @relation(fields: [clinicId], references: [id])
  channelPref   Channel    @default(wa)
  treatmentIds  String[]   @db.Uuid
  regions       String[]
  kind          LeadKind[]
  status        LeadStatus @default(new)
  photos        String[]
  message       String?
  // NO PRICE FIELD. EVER.

  koreaVisit    KoreaVisit?
  messages      Message[]
  notes         Note[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([ownerId, status])
}

model Clinic {
  id            String              @id @default(uuid()) @db.Uuid
  slug          String              @unique
  name          Json                // { kz, ru, kr }
  kind          ClinicKind
  location      Json                // { country, city, area, geo: [lat, lng] }
  interpreters  String[]
  treatmentIds  String[]            @db.Uuid
  verifyState   ClinicVerifyState   @default(pending)
  hours         Json
  about         Json?               // { kz, ru, kr }

  leads         Lead[]
  reviews       Review[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model Treatment {
  id            String            @id @default(uuid()) @db.Uuid
  slug          String            @unique
  category      TreatmentCategory
  title         Json              // { kz, ru, kr }
  summary       Json              // { kz, ru, kr }
  durationMin   Int
  recovery      Json              // { kz, ru, kr }
  expects       Json              // { kz: string[], ru: string[], kr: string[] }
  // NO PRICE FIELD. EVER.

  reviews       Review[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model Review {
  id            String      @id @default(uuid()) @db.Uuid
  code          String      @unique
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  clinicId      String?     @db.Uuid
  clinic        Clinic?     @relation(fields: [clinicId], references: [id])
  txId          String?     @db.Uuid
  treatment     Treatment?  @relation(fields: [txId], references: [id])
  rating        Int
  body          String
  photos        String[]
  photoConsent  Boolean     @default(false)
  state         ReviewState @default(pending)
  flagReason    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([state, createdAt(sort: Desc)])
}

model Message {
  id            String           @id @default(uuid()) @db.Uuid
  leadId        String           @db.Uuid
  lead          Lead             @relation(fields: [leadId], references: [id])
  channel       Channel
  direction     MessageDirection
  body          String
  templateId    String?          @db.Uuid
  template      Template?        @relation(fields: [templateId], references: [id])
  status        MessageStatus    @default(queued)
  providerId    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leadId, createdAt])
  @@index([status])
}

model Template {
  id            String   @id @default(uuid()) @db.Uuid
  key           String   @unique
  channels      Channel[]
  bodies        Json     // { [channel]: { kz, ru, kr } }
  vars          String[]
  auto          Boolean  @default(false)

  messages      Message[]
  rules         AutomationRule[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AutomationRule {
  id            String            @id @default(uuid()) @db.Uuid
  trigger       AutomationTrigger
  delayMin      Int               @default(0)
  templateId    String            @db.Uuid
  template      Template          @relation(fields: [templateId], references: [id])
  channel       Channel
  paused        Boolean           @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model KoreaVisit {
  id            String   @id @default(uuid()) @db.Uuid
  leadId        String   @unique @db.Uuid
  lead          Lead     @relation(fields: [leadId], references: [id])
  dateFrom      DateTime
  dateTo        DateTime
  airport       String?
  hotelPref     String?
  interpreter   String?
  aftercareDays Int?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Favorite {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @db.Uuid
  user      User   @relation(fields: [userId], references: [id])
  kind      String // 'treatment' | 'clinic'
  refId     String @db.Uuid

  createdAt DateTime @default(now())

  @@unique([userId, kind, refId])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  kind      String   // 'consult' | 'review' | 'promo'
  title     Json     // { kz, ru, kr }
  body      Json     // { kz, ru, kr }
  read      Boolean  @default(false)
  meta      Json?

  createdAt DateTime @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  lead      Lead     @relation(fields: [leadId], references: [id])
  authorId  String   @db.Uuid
  body      String
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  ip        String?
  ua        String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String   @db.Uuid
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String   @db.Uuid
  before    Json?
  after     Json?
  ip        String?
  ua        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId, createdAt(sort: Desc)])
}
